PORT=4000
MONGODB_URI=mongodb://localhost:27017/game-guide
JWT_SECRET=your-super-secret-jwt-key-change-in-production
RAWG_API_KEY=your-rawg-api-key
# Optional: outbound HTTP proxy (e.g. local clash). Leave unset on Railway for direct internet access.
# PROXY_URL=http://127.0.0.1:7897
# Baidu translate credentials (required for Baidu translation engine)
BAIDU_TRANSLATE_APP_ID=your-baidu-translate-app-id
BAIDU_TRANSLATE_API_KEY=your-baidu-translate-api-key
# 浏览器里打开「前端」时的域名（可写 https://完整域名，也可只写域名，后端会自动补 https://）
# 多个用英文逗号；不要用后端域名，除非前后端同域。
# 调试可设为 *。
CORS_ORIGIN=http://localhost:3000