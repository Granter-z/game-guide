# 前端请求后端 API 的基础地址（Vite 在「构建时」注入）
# 本地开发通常使用 /api（配合 Vite proxy）
VITE_API_BASE_URL=/api

# 推荐（Railway 等）：构建变量 BACKEND_API_BASE，与上面二选一即可；prebuild 会写入 public/runtime-config.js
# 须以 /api 结尾，例如 https://你的后端.up.railway.app/api
# BACKEND_API_BASE=https://你的后端.up.railway.app/api

# 也可直接改仓库里的 frontend/public/runtime-config.js 里的 window.__GAME_GUIDE_API_BASE__，再部署前端

# 后端 CORS_ORIGIN 需包含前端页面完整 origin（含 https://，无路径）
